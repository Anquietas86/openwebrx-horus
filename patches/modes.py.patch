# --- Horus Binary (4FSK) ---
# Bandwidth: Horus 4FSK uses ~10 kHz occupied bandwidth at 100 baud.
# The mode is presented as a digital mode underlying NFM demodulation.

DigitalMode(
    modulation="horus_binary",
    name="Horus Binary",
    underlying="nfm",
    bandpass=Bandpass(-4000, 4000),
    ifRate=48000,
    requirements=["horusdemodlib"],
    service=True,
),
DigitalMode(
    modulation="horus_rtty",
    name="Horus RTTY",
    underlying="usb",
    bandpass=Bandpass(300, 3000),
    ifRate=48000,
    requirements=["horusdemodlib"],
    service=True,
),
