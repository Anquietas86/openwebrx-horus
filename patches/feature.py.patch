def has_horusdemodlib(self):
    """Check if horusdemodlib is installed and the C modem is available."""
    try:
        from horusdemodlib.demod import HorusLib, Mode
        # Verify the CFFI C extension loaded successfully
        test = HorusLib(mode=Mode.BINARY, sample_rate=48000)
        test.close()
        return True
    except Exception:
        return False
